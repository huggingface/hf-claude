#!/usr/bin/env bash
# Claude launcher for Hugging Face Inference Providers with model/provider selection.
# Auth: uses $HF_TOKEN if set, else the token saved by `hf auth login`.
# fzf is used for selection when available, with an arrow-key menu fallback.

set -euo pipefail

# Parse wrapper flags, forwarding everything else to `claude`.
#   --bill-to <org> / --bill-to=<org>  bill inference to a HF org (X-HF-Bill-To)
# Falls back to $HF_BILL_TO when the flag is absent.
BILL_TO="${HF_BILL_TO:-}"
CLAUDE_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) exec claude --help ;;
    --bill-to)
      BILL_TO="${2:-}"
      if [[ -z "$BILL_TO" ]]; then
        echo "Error: --bill-to requires an organization name." >&2
        exit 1
      fi
      shift 2
      ;;
    --bill-to=*) BILL_TO="${1#*=}"; shift ;;
    *) CLAUDE_ARGS+=("$1"); shift ;;
  esac
done

# --- Favor Exa MCP for web search on this HF endpoint ---
# On the HF router (router.huggingface.co), the CLI's native WebSearch calls
# Anthropic's dedicated search backend, which rejects the HF token used here as
# ANTHROPIC_API_KEY — so WebSearch returns empty/leaked/hallucinated output
# instead of real results. (Native WebFetch still works: it fetches URLs
# harness-side and doesn't need the search backend.) Exa's hosted MCP
# (https://mcp.exa.ai/mcp) provides web_search_exa / web_fetch_exa and runs
# keyless on a free, rate-limited tier, so it gives working web search on this
# endpoint with no Anthropic dependency.
# We *allow* the Exa tools and nudge the model toward them; we do NOT *deny*
# the native tools, because in auto-permission mode that makes the advisor
# treat allowing Exa as "circumventing" the deny and blocks it too — leaving
# the native tools available as a fallback is the safe choice.
EXA_MCP_URL="https://mcp.exa.ai/mcp"
EXA_FLAGS=(
  --settings '{"permissions":{"allow":["mcp__exa__web_search_exa","mcp__exa__web_fetch_exa"]}}'
  --append-system-prompt 'For web search and fetching web pages, use the Exa MCP tools (mcp__exa__web_search_exa, mcp__exa__web_fetch_exa) rather than the native WebSearch tool, which does not return results on this endpoint.'
)

# Skip if the user disabled it, or already passed one of these flags.
want_exa=1
[[ "${HF_CLAUDE_EXA:-1}" == "0" ]] && want_exa=0
for arg in ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}; do
  case "$arg" in --settings|--append-system-prompt) want_exa=0 ;; esac
done

if (( want_exa )); then
  if ! claude mcp list 2>/dev/null | grep -q '^exa:'; then
    # Not installed: offer a keyless install, but only when interactive.
    if [[ -t 0 && -t 2 ]] && command -v claude >/dev/null 2>&1; then
      printf 'Exa MCP (web search) is not configured. Install it now (free, no API key)? [Y/n] ' >&2
      read -r ans
      if [[ "${ans:-y}" =~ ^[Yy]$ ]]; then
        if ! claude mcp add --transport http exa "$EXA_MCP_URL" -s user >/dev/null 2>&1; then
          echo "Warning: Exa MCP install failed; skipping Exa favoring." >&2
          want_exa=0
        fi
      else
        want_exa=0
      fi
    else
      # Non-interactive and missing: don't nudge toward a tool that isn't there.
      want_exa=0
    fi
  fi
fi

HF_TOKEN="${HF_TOKEN:-}"

# Fall back to the token saved by `hf auth login` when HF_TOKEN isn't set.
# `hf auth token` prints the active token and honors `hf auth switch`.
if [[ -z "$HF_TOKEN" ]] && command -v hf >/dev/null 2>&1; then
  HF_TOKEN="$(hf auth token 2>/dev/null || true)"
fi

if [[ -z "$HF_TOKEN" ]]; then
  echo "Error: no Hugging Face token found." >&2
  echo "Log in with:        hf auth login" >&2
  echo "or export a token:  export HF_TOKEN='hf_...'" >&2
  exit 1
fi

for cmd in curl jq claude; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "Error: '$cmd' is required but not found in PATH." >&2
    exit 1
  fi
done

# Pick one line from stdin. Uses fzf when installed; otherwise falls back to a
# pure-bash arrow-key menu so fzf stays optional.
pick() {
  local prompt="$1" header="$2"
  if command -v fzf >/dev/null 2>&1; then
    fzf --prompt="$prompt" --height=50% --reverse --header="$header"
    return
  fi
  _arrow_menu "$header"
}

# Arrow-key selection menu (no fzf needed). Reads candidate lines from stdin,
# draws a scrolling list on the terminal (stderr) starting at the top, and
# prints the chosen line to stdout. Up/Down or j/k move, g/G or Home/End jump
# to ends, Enter selects, q/Esc/Ctrl-C cancel (prints nothing).
_arrow_menu() {
  local header="$1"
  local items=() line
  while IFS= read -r line; do items+=("$line"); done
  set +e  # interactive reads/arithmetic below may "fail" benignly under set -e
  local n=${#items[@]}
  (( n == 0 )) && return 0
  if [[ ! -t 2 || ! -r /dev/tty ]]; then
    echo "no-fzf menu needs an interactive terminal; install fzf for selection" >&2
    return 0
  fi

  local size rows cols
  size=$(stty size </dev/tty 2>/dev/null)
  rows=${size%% *}; cols=${size##* }
  [[ $rows =~ ^[0-9]+$ ]] || rows=24
  [[ $cols =~ ^[0-9]+$ ]] || cols=80
  local vh=$(( rows - 4 )) maxw=$(( cols - 4 ))
  (( vh < 1 ))   && vh=1
  (( vh > n ))   && vh=$n
  (( maxw < 8 )) && maxw=8

  local saved; saved=$(stty -g </dev/tty 2>/dev/null)
  trap 'stty "$saved" </dev/tty 2>/dev/null; printf "\e[?25h" >&2' EXIT
  trap 'stty "$saved" </dev/tty 2>/dev/null; printf "\e[?25h\n" >&2; exit 130' INT TERM
  stty -echo -icanon </dev/tty 2>/dev/null
  printf '\e[?25l' >&2   # hide cursor

  local sel=0 top=0 drawn=0 key rest i disp buf
  while true; do
    (( sel < top ))       && top=$sel
    (( sel >= top + vh )) && top=$(( sel - vh + 1 ))
    buf=""
    (( drawn )) && buf+=$'\e['"$(( vh + 2 ))"'A'
    drawn=1
    buf+=$'\r\e[2K\e[1m'"$header"$'\e[0m\n'
    for (( i = top; i < top + vh; i++ )); do
      disp=${items[i]:0:maxw}
      if (( i == sel )); then
        buf+=$'\r\e[2K\e[7m> '"$disp"$' \e[0m\n'
      else
        buf+=$'\r\e[2K  '"$disp"$'\n'
      fi
    done
    buf+=$'\r\e[2K\e[2m'"  [$(( sel + 1 ))/$n]  up/down move - enter select - q quit"$'\e[0m\n'
    printf '%s' "$buf" >&2

    IFS= read -rsn1 key </dev/tty || { sel=-1; break; }
    if [[ $key == $'\e' ]]; then
      # integer timeout: macOS stock bash 3.2 rejects fractional -t
      read -rsn2 -t 1 rest </dev/tty
      case "$rest" in
        '[A') (( sel > 0 ))     && sel=$(( sel - 1 )) ;;
        '[B') (( sel < n - 1 )) && sel=$(( sel + 1 )) ;;
        '[H') sel=0 ;;
        '[F') sel=$(( n - 1 )) ;;
        '')   sel=-1; break ;;          # bare Esc = cancel
      esac
    else
      case "$key" in
        k) (( sel > 0 ))     && sel=$(( sel - 1 )) ;;
        j) (( sel < n - 1 )) && sel=$(( sel + 1 )) ;;
        g) sel=0 ;;
        G) sel=$(( n - 1 )) ;;
        q|Q)            sel=-1; break ;;
        ''|$'\n'|$'\r') break ;;        # Enter = select current
      esac
    fi
  done

  printf '\e[%dA\r\e[J' "$(( vh + 2 ))" >&2   # erase the menu block
  stty "$saved" </dev/tty 2>/dev/null
  printf '\e[?25h' >&2
  trap - EXIT INT TERM

  (( sel < 0 )) && return 0
  printf '%s\n' "${items[sel]}"
}

MODEL_DATA="$(curl -fsS "https://router.huggingface.co/v1/models" \
  -H "Authorization: Bearer ${HF_TOKEN}")"

MODEL="$(echo "$MODEL_DATA" | jq -r '.data[].id' \
  | pick "Model: " "Hugging Face Inference Providers - Select Model")"

if [[ -z "$MODEL" ]]; then
  echo "No model selected"
  exit 1
fi

PROVIDER="$(
  {
    echo "auto"
    echo "$MODEL_DATA" | jq -r --arg model "$MODEL" '.data[] | select(.id == $model) | .providers[].provider'
  } | awk '!seen[$0]++' \
    | pick "Provider: " "Select Provider for ${MODEL} (auto = no suffix)"
)"

if [[ -z "$PROVIDER" ]]; then
  echo "No provider selected"
  exit 1
fi

if [[ "$PROVIDER" == "auto" ]]; then
  MODEL_STRING="$MODEL"
else
  MODEL_STRING="${MODEL}:${PROVIDER}"
fi

echo "→ claude @ ${MODEL_STRING}" >&2

export ANTHROPIC_API_KEY="$HF_TOKEN"
export ANTHROPIC_AUTH_TOKEN="$HF_TOKEN"
export ANTHROPIC_BASE_URL="https://router.huggingface.co"
export ANTHROPIC_DEFAULT_SONNET_MODEL="$MODEL_STRING"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="$MODEL_STRING"
export ANTHROPIC_DEFAULT_OPUS_MODEL="$MODEL_STRING"
export ANTHROPIC_DEFAULT_FABLE_MODEL="$MODEL_STRING"
export CLAUDE_CODE_SUBAGENT_MODEL="$MODEL_STRING"

# Bill inference to a HF org via the router's X-HF-Bill-To header. Appended so
# any user-supplied ANTHROPIC_CUSTOM_HEADERS are preserved.
if [[ -n "$BILL_TO" ]]; then
  if [[ -n "${ANTHROPIC_CUSTOM_HEADERS:-}" ]]; then
    export ANTHROPIC_CUSTOM_HEADERS="${ANTHROPIC_CUSTOM_HEADERS}
X-HF-Bill-To: ${BILL_TO}"
  else
    export ANTHROPIC_CUSTOM_HEADERS="X-HF-Bill-To: ${BILL_TO}"
  fi
  echo "→ billing to org: ${BILL_TO}" >&2
fi

if (( want_exa )); then
  exec claude --model "$MODEL_STRING" "${EXA_FLAGS[@]}" ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}
else
  exec claude --model "$MODEL_STRING" ${CLAUDE_ARGS[@]+"${CLAUDE_ARGS[@]}"}
fi
